{
  "Hexfield Planner Frontmatter": {
    "prefix": "hfm",
    "description": "Hexfield planner frontmatter block",
    "body": [
      "---",
      "type: hexfield-planner",
      "week: $1",
      "year: ${2:2026}",
      "startDate: $3",
      "endDate: $4",
      "---",
      ""
    ]
  },
  "Day Section": {
    "prefix": "hfd",
    "description": "Day section heading with a starter task",
    "body": ["## ${1:Monday}, ${2:January 1, 2026}", "", "- [ ] $0"]
  },
  "Hexfield Task": {
    "prefix": "hft",
    "description": "Full Hexfield task line with all tokens",
    "body": [
      "- [ ] ${1:description} #${2:project} [${3:YYYY-MM-DD}] ${4:!!} est:${5:1h}"
    ]
  },
  "Time Estimate": {
    "prefix": "est",
    "description": "Time estimate token",
    "body": ["est:${1|15m,30m,1h,2h,4h,8h|}"]
  },
  "Priority HIGH": {
    "prefix": "phi",
    "description": "HIGH priority marker (!!!)",
    "body": ["!!!"]
  },
  "Priority MED": {
    "prefix": "pme",
    "description": "MED priority marker (!!)",
    "body": ["!!"]
  },
  "Priority LOW": {
    "prefix": "plo",
    "description": "LOW priority marker (!)",
    "body": ["!"]
  }
}
